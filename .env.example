# ─────────────────────────────────────────────
#  Personal Assistant Agent — Environment Setup
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── Anthropic (required) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# ── Twilio SMS ────────────────────────────────
# Get these from https://console.twilio.com
# Leave blank to disable SMS features.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890   # Your Twilio number in E.164 format

# ── Microsoft Graph / Outlook ─────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Required permissions: Mail.Read, Mail.Send (delegated)
# Leave blank to disable email features.
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=common   # or your specific tenant ID

# ── Google Calendar ───────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Enable the Google Calendar API
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download the JSON file and set the path below
# Leave blank to disable calendar features.
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_CALENDAR_ID=primary  # or a specific calendar ID
